<Window x:Class="Cyberbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cyber bot 36"
        Height="501"
        Width="800"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Grid Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="121"/>
            <RowDefinition Height="221"/>
            <RowDefinition Height="108"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <Image
                   Source="/depositphotos_176577870-stock-illustration-cute-smiling-funny-robot-chat.jpg"
                   Width="128"
                   Height="107"
                   Stretch="UniformToFill"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top" RenderTransformOrigin="0.524,0.126"/>

            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,0,0,0">

                <Label Content="Chat bot UI"
                       Width="414"
                       Height="73"
                       HorizontalContentAlignment="Center"
                       FontSize="36"
                       FontWeight="Bold"
                       Foreground="#FF253AEC" FontFamily="Ravie"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,4,0,0">

                    <Image Source="/green dot.png"
                           Width="31"
                           Height="18"
                           Stretch="Uniform"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"/>

                    <Label Content="Online"
                           Height="35"
                           FontWeight="Bold"
                           FontSize="18"
                           Padding="0"/>
                </StackPanel>
            </StackPanel>

            <Border Height="3"
                    Background="Black"
                    VerticalAlignment="Bottom"
                    Grid.ColumnSpan="3"/>
        </Grid>

        <Border Grid.Row="1"
                BorderBrush="Black"
                BorderThickness="1"
                Background="#ECE5DD">

            <ListBox x:Name="MessagesList"
                     ItemsSource="{Binding Messages}"
                     Background="#FFDDE8EC"
                     BorderThickness="0"
                     Padding="10"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="0,-1,0,0">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4">
                            <StackPanel HorizontalAlignment="{Binding Alignment}"
                                        MaxWidth="480">

                                <Border Background="{Binding BubbleBackground}"
                                        CornerRadius="{Binding BubbleCornerRadius}"
                                        Padding="10"
                                        BorderBrush="#DDDDDD"
                                        BorderThickness="1">

                                    <StackPanel>
                                        <TextBlock Text="{Binding Sender}"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding SenderColor}"
                                                   Margin="0,0,0,3"/>

                                        <TextBlock Text="{Binding Text}"
                                                   TextWrapping="Wrap"
                                                   FontSize="15"
                                                   Foreground="Black"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{Binding Time}"
                                           FontSize="10"
                                           Foreground="#666666"
                                           HorizontalAlignment="{Binding Alignment}"
                                           Margin="5,2,5,0"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="2" RenderTransformOrigin="0.5,0.315">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="77"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="140"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0"
                   Source="/girl.jpeg"
                   Width="62"
                   Height="75"
                   Stretch="UniformToFill"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

            <TextBox x:Name="txtMessage"
                     Grid.Column="1"
                     Height="58"
                     TextWrapping="Wrap"
                     Text="Text Message ...."
                     VerticalAlignment="Center"
                     FontSize="22"
                     Foreground="#FF5A5454"
                     Padding="12"
                     BorderBrush="Black"
                     BorderThickness="1"
                     GotFocus="txtMessage_GotFocus"
                     LostFocus="txtMessage_LostFocus"
                     KeyDown="txtMessage_KeyDown"/>

            <Button x:Name="btnSend"
                    Grid.Column="2"
                    Content="Send"
                    Width="98"
                    Height="44"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,5,0,0"
                    FontWeight="Bold"
                    FontSize="16"
                    Click="btnSend_Click" Background="#FF7FB9EF"/>
        </Grid>

    </Grid>
</Window>